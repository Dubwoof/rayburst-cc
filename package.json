{
  "name": "@rayburst/cc",
  "version": "3.1.9",
  "type": "module",
  "description": "Always-on product context for Claude Code. Automatically injects feature atlas and acceptance criteria into every coding session.",
  "author": {
    "name": "Rayburst",
    "email": "hello@rayburst.app"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dubwoof/rayburst-cc.git"
  },
  "homepage": "https://rayburst.app",
  "keywords": [
    "claude",
    "claude-code",
    "rayburst",
    "mcp",
    "ai",
    "product-management",
    "feature-tracking",
    "qa-validation",
    "acceptance-criteria"
  ],
  "files": [
    "server.bundle.mjs",
    "start.mjs",
    "hooks",
    "skills",
    ".claude-plugin",
    ".mcp.json"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:hooks",
    "build:server": "esbuild src/server.ts --bundle --platform=node --target=node18 --format=esm --outfile=server.bundle.mjs --minify",
    "build:hooks": "node scripts/build-hooks.mjs",
    "dev": "npx tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
